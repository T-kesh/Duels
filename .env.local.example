# ─── Session store (Upstash Redis — required on Vercel to survive cold starts)
# Create a free database at https://console.upstash.com → copy REST URL + token
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxx

# ─── AI duel (Anthropic)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ─── On-chain signatures (claims + PvP settlement)
# Hex private key controlling DuelRewards.owner (same key used by claim/reward signer)
PRIVATE_KEY=0xabc...

# Optional RPC for server routes (PvP verifier, AI claim session N/A chain reads, top-ups)
CELO_RPC_URL=https://...
NEXT_PUBLIC_RPC_URL=https://...

# DuelRewards proxy (frontend + server overrides)
NEXT_PUBLIC_DUEL_REWARDS_ADDRESS=0x077E207a9DAAE8Fb1c425906E0607A1a61e187F1

# cUSD + energy top-ups
NEXT_PUBLIC_CUSD_ADDRESS=
TOPUP_TREASURY=
NEXT_PUBLIC_TOPUP_TREASURY=
TOPUP_AMOUNT_WEI=5000000000000000
NEXT_PUBLIC_TOPUP_AMOUNT_WEI=5000000000000000

# Optional: OpenAI fallback (unused by default paths)
OPENAI_API_KEY=

# WalletConnect legacy flag (currently unused — injected-first config)
NEXT_PUBLIC_WC_PROJECT_ID=
